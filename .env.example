# ============================================================
# 서울 난지캠핑장 잔여 알리미 설정
# ============================================================

# Telegram 봇 토큰 (@BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram 채팅 ID (@userinfobot 으로 확인)
# 개인 채팅: 숫자 ID (예: 123456789)
# 그룹 채팅: 음수 ID (예: -123456789)
TELEGRAM_CHAT_ID=your_chat_id_here

# 실행 모드: scheduler(매시간 반복) 또는 once(1회 실행)
MODE=scheduler

# 체크 주기 (분 단위, 기본 60분)
CHECK_INTERVAL_MINUTES=60

# 확인할 주 수 (기본 8주 = 약 2개월)
LOOK_AHEAD_WEEKS=8

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
